{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "tampermonkey"
    ]
  },
  "include": [
    "src",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
